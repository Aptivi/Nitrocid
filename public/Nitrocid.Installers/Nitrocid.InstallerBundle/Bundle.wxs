<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle Name="Nitrocid" Manufacturer="Aptivi" Version="0.2.0.11" UpgradeCode="7011d1b2-1bb0-49db-8a25-035d5b47ce9a" IconSourceFile="..\..\..\..\..\..\Nitrocid\OfficialAppIcon-Nitrocid.ico">
    <BootstrapperApplication>
      <bal:WixInternalUIBootstrapperApplication />
    </BootstrapperApplication>

    <Variable Name="NitrocidLite" Type="string" Value="0" bal:Overridable="yes" />

    <Chain>
      <MsiPackage SourceFile="Nitrocid.Installer.msi">
        <MsiProperty Name="NOADDONS" Value="[NitrocidLite]" />
      </MsiPackage>
    </Chain>
  </Bundle>
</Wix>
